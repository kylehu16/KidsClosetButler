<view class="child-edit-page">
  <view class="nav-bar gradient-bg">
    <view class="nav-back" bindtap="goBack">←</view>
    <view class="nav-title">{{isEdit ? '编辑宝贝' : '添加宝贝'}}</view>
  </view>

  <view class="form-content">
    <view class="form-card card">
      <view class="form-item">
        <view class="form-label">姓名</view>
        <input 
          class="form-input" 
          placeholder="请输入宝贝姓名"
          value="{{childForm.name}}"
          bindinput="onInput"
          data-field="name"
        />
      </view>
      
      <view class="form-item">
        <view class="form-label">出生日期</view>
        <picker mode="date" value="{{childForm.birthDate}}" bindchange="onBirthDateChange">
          <view class="form-input picker-input">
            {{childForm.birthDate || '请选择出生日期'}}
          </view>
        </picker>
      </view>

      <view class="form-row">
        <view class="form-item">
          <view class="form-label">身高 (cm)</view>
          <input 
            class="form-input" 
            type="number"
            placeholder="请输入身高"
            value="{{childForm.height}}"
            bindinput="onInput"
            data-field="height"
          />
        </view>
      </view>

      <view class="form-row">
        <view class="form-item">
          <view class="form-label">脚长 (mm)</view>
          <input 
            class="form-input" 
            type="number"
            placeholder="请输入脚长"
            value="{{childForm.footLength}}"
            bindinput="onInput"
            data-field="footLength"
          />
        </view>
      </view>
      
      <view class="form-item">
        <view class="form-label">性别</view>
        <view class="gender-options">
          <view 
            class="gender-item {{childForm.gender === 1 ? 'active' : ''}}"
            data-gender="1"
            bindtap="selectGender"
          >👦 男宝</view>
          <view 
            class="gender-item {{childForm.gender === 0 ? 'active' : ''}}"
            data-gender="0"
            bindtap="selectGender"
          >👧 女宝</view>
        </view>
      </view>
    </view>
    
    <button class="save-btn" bindtap="saveChild">保存</button>
    
    <button wx:if="{{isEdit}}" class="delete-btn" bindtap="deleteChild">删除宝贝</button>
  </view>
</view>