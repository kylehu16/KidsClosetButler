<view class="wardrobe-page">
  <view class="nav-bar gradient-bg">
    <view class="nav-title">👶 儿童衣橱管家</view>
    <view class="nav-subtitle">智能管理宝贝的每一件衣物</view>
  </view>
  
  <view class="category-tabs">
    <view 
      wx:for="{{categories}}" 
      wx:key="id"
      class="tab-item {{selectedCategory === item.id ? 'active' : ''}}"
      data-id="{{item.id}}"
      bindtap="selectCategory"
    >
      {{item.name}}
    </view>
  </view>
  
  <view class="stats-cards">
    <view class="stat-card">
      <view class="stat-num">{{totalCount}}</view>
      <view class="stat-label">总件数</view>
    </view>
    <view class="stat-card">
      <view class="stat-num">{{categoryCount}}</view>
      <view class="stat-label">分类</view>
    </view>
    <view class="stat-card">
      <view class="stat-num">{{weekCount}}</view>
      <view class="stat-label">本周穿搭</view>
    </view>
  </view>
  
  <view class="add-btn" bindtap="goToAdd">
    <text class="add-btn-icon">+</text>
    <text class="add-btn-text">添加衣物</text>
  </view>
  
  <!-- 搜索框 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索衣物名称..." 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
      />
      <text 
        wx:if="{{searchKeyword}}" 
        class="search-clear" 
        bindtap="onClearSearch"
      >✕</text>
    </view>
  </view>
  
  <scroll-view class="clothes-list" scroll-y>
    <view class="clothes-grid">
      <view 
        wx:for="{{displayClothes}}" 
        wx:key="id"
        class="clothes-card card"
      >
        <view class="clothes-img" data-id="{{item.id}}" bindtap="goToDetail">
          <image wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill"/>
          <view wx:else class="img-placeholder">
            <text>{{item.name[0]}}</text>
          </view>
        </view>
        <view class="clothes-info">
          <view class="clothes-name">{{item.name}}</view>
          <view class="clothes-meta">
            <text class="tag tag-gray">{{item.size}}{{item.sizeUnit}}</text>
            <text class="tag tag-gray">{{item.categoryText}}</text>
            <text class="tag tag-purple">{{item.seasonText}}</text>
          </view>
        </view>
        <view class="clothes-actions">
          <view class="action-btn wear-btn" data-id="{{item.id}}" bindtap="showWearModal">
            <text>👕 穿这件</text>
          </view>
          <view class="action-btn delete-btn" data-id="{{item.id}}" bindtap="onDelete">
            <text>🗑️ 删除</text>
          </view>
        </view>
      </view>
    </view>
    
    <view wx:if="{{displayClothes.length === 0}}" class="empty-state">
      <text class="empty-text">暂无衣物，点击上方"添加衣物"</text>
    </view>
    
    <!-- 加载更多 -->
    <view wx:if="{{hasMore}}" class="load-more" bindtap="loadMore">
      <text>加载更多</text>
    </view>
    <view wx:if="{{!hasMore && displayClothes.length > 0}}" class="load-more no-more">
      <text>— 已经到底了 —</text>
    </view>
  </scroll-view>
  
  <!-- 穿这件弹窗 -->
  <view class="wear-modal {{showWearModal ? 'show' : ''}}" bindtap="hideWearModal">
    <view class="wear-modal-content" catchtap="stopPropagation">
      <view class="wear-modal-title">记录穿着</view>
      
      <!-- 选择儿童 -->
      <view class="wear-modal-section">
        <view class="wear-modal-label">选择儿童</view>
        <view class="wear-child-list">
          <view 
            wx:for="{{children}}"
            wx:key="id"
            class="wear-child-item {{wearSelectedChildId === item.id ? 'active' : ''}}"
            data-id="{{item.id}}"
            bindtap="selectWearChild"
          >
            <view class="wear-child-avatar">{{item.avatar}}</view>
            <view class="wear-child-name">{{item.name}}</view>
          </view>
        </view>
      </view>

      <!-- 选择日期 -->
      <view class="wear-modal-section">
        <view class="wear-modal-label">选择日期</view>
        <picker mode="date" value="{{wearDate}}" bindchange="onWearDateChange">
          <view class="wear-date-picker">
            <text>{{wearDate || '请选择日期'}}</text>
            <text class="wear-date-arrow">▸</text>
          </view>
        </picker>
      </view>

      <!-- 按钮 -->
      <view class="wear-modal-btns">
        <view class="wear-btn-cancel" bindtap="hideWearModal">取消</view>
        <view class="wear-btn-confirm" bindtap="confirmWear">确定</view>
      </view>
    </view>
  </view>
  
  <tab-bar currentIndex="0"></tab-bar>
</view>