.wardrobe-page {
  min-height: 100vh;
  background: #F9FAFB;
  padding-bottom: calc(120rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.nav-bar {
  height: 180rpx;
  padding: 60rpx 32rpx 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.nav-subtitle {
  font-size: 28rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.9);
}

.category-tabs {
  display: flex;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  gap: 16rpx;
  overflow-x: auto;
}

.category-tabs::-webkit-scrollbar { display: none; }

.tab-item {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #4A5565;
  white-space: nowrap;
  background: #F3F4F6;
}

.tab-item.active {
  background: linear-gradient(135deg, #FB64B6 0%, #C27AFF 100%);
  color: #FFFFFF;
}

.stats-cards {
  display: flex;
  padding: 24rpx 32rpx 12rpx;
  gap: 20rpx;
}

.stat-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #FB64B6;
}

.stat-label {
  font-size: 22rpx;
  color: #6B7280;
  margin-top: 8rpx;
}

.clothes-list {
  height: calc(100vh - 640rpx - constant(safe-area-inset-bottom));
  height: calc(100vh - 640rpx - env(safe-area-inset-bottom));
}

.clothes-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin: 0 24rpx;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

.clothes-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.clothes-img {
  width: 100%;
  height: 280rpx;
  background: #F3F4F6;
}

.clothes-img image {
  width: 100%;
  height: 100%;
}

.img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FB64B6 0%, #C27AFF 100%);
}

.img-placeholder text {
  font-size: 64rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.clothes-info {
  padding: 20rpx;
}

.clothes-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1F2937;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.clothes-meta {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.clothes-actions {
  display: flex;
  padding: 0 20rpx 20rpx;
  gap: 12rpx;
}

.action-btn {
  flex: 1;
  padding: 12rpx 0;
  text-align: center;
  font-size: 24rpx;
  border-radius: 8rpx;
  background: #F3F4F6;
  color: #4A5565;
}

.edit-btn {
  background: rgba(59, 130, 246, 0.1);
  color: #3B82F6;
}

.delete-btn {
  background: rgba(239, 68, 68, 0.1);
  color: #EF4444;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #9CA3AF;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin: 12rpx 24rpx 16rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #FB64B6 0%, #C27AFF 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(251, 100, 182, 0.3);
}

.add-btn-icon {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.add-btn-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
}