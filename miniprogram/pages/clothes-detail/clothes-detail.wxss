/* 页面容器 */
.detail-page {
  min-height: 100vh;
  background: #F9FAFB;
}

/* 导航栏 - 与添加衣物页面保持一致 */
.nav-bar {
  height: 180rpx;
  padding:0 32rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 20rpx;
  position: relative;
}

.nav-back {
  position: absolute;
  left: 32rpx;
  bottom: 20rpx;
  font-size: 40rpx;
  color: #FFFFFF;
  padding: 10rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

/* 内容区域 */
.detail-content {
  height: calc(100vh - 200rpx);
  padding: 24rpx;
}

/* 图片区域 */
.image-section {
  width:100%;
  height: 500rpx;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  background: #FFFFFF;
  box-shadow:0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.clothes-image {
  width:100%;
  height:100%;
}

.image-placeholder {
  width:100%;
  height:100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.placeholder-text {
  font-size: 120rpx;
  color: #FFFFFF;
  font-weight: bold;
}

/* 信息区域 */
.info-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow:0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.info-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom:1rpx solid #F3F4F6;
}

.clothes-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #1F2937;
}

.wear-count {
  font-size: 24rpx;
  color: #6B7280;
  background: #F3F4F6;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* 信息网格 */
.info-grid {
  display: grid;
  grid-template-columns:1fr 1fr;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-label {
  font-size: 24rpx;
  color: #9CA3AF;
}

.info-value {
  font-size: 28rpx;
  color: #1F2937;
  font-weight: 500;
}

/* 颜色显示 */
.color-display {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.color-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border:2rpx solid #E5E7EB;
}

/* 标签区域 */
.tags-section {
  margin-bottom: 32rpx;
  padding-top: 24rpx;
  border-top:1rpx solid #F3F4F6;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.tag-purple {
  background: rgba(139, 92, 246,0.1);
  color: #8B5CF6;
}

/* 时间区域 */
.time-section {
  padding-top: 24rpx;
  border-top:1rpx solid #F3F4F6;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

/* 操作按钮区域 */
.action-section {
  display: flex;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.action-btn {
  flex:1;
  padding: 28rpx;
  border-radius: 16rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
}

.edit-action {
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
  color: #FFFFFF;
  box-shadow:0 4rpx 20rpx rgba(59, 130, 246, 0.3);
}

.edit-action:active {
  transform: scale(0.95);
}

.delete-action {
  background: #FFFFFF;
  color: #EF4444;
  border:2rpx solid #EF4444;
}

.delete-action:active {
  background: #FEF2F2;
}

/* 空状态 */
.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.empty-text {
  font-size: 28rpx;
  color: #9CA3AF;
}
