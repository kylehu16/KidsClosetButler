.outfit-page {
  min-height: 100vh;
  background: #F9FAFB;
  padding-bottom: 140rpx;
}

.nav-bar {
  height: 180rpx;
  padding: 60rpx 32rpx 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.nav-subtitle {
  font-size: 28rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.9);
}

.outfit-content {
  padding: 0 32rpx;
  margin-top: 24rpx;
}

.section-header {
  padding: 24rpx 0;
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-icon {
  font-size: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0A0A0A;
}

.section-title-bold {
  font-size: 32rpx;
  font-weight: 700;
  color: #0A0A0A;
}

.mode-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.mode-tab {
  flex: 1;
  padding: 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  text-align: center;
  font-size: 28rpx;
  color: #364153;
  border: 2rpx solid #E5E7EB;
}

.mode-tab.active {
  background: #AD46FF;
  border-color: #AD46FF;
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(173, 70, 255, 0.3);
}

.section {
  margin-bottom: 24rpx;
}

.section-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #101828;
  margin-bottom: 16rpx;
}

.child-list {
  display: flex;
  gap: 16rpx;
}

.child-card {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 2rpx solid #E5E7EB;
}

.child-card.active {
  background: #F0FDF4;
  border-color: #00C950;
}

.child-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FB64B6 0%, #C27AFF 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 16rpx;
}

.child-info {
  flex: 1;
}

.child-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #101828;
}

.child-desc {
  font-size: 24rpx;
  color: #6A7282;
  margin-top: 4rpx;
}

.weather-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.weather-item {
  padding: 24rpx 16rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  text-align: center;
  border: 2rpx solid #E5E7EB;
}

.weather-item.active {
  background: #F0FDF4;
  border-color: #00C950;
}

.weather-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.weather-name {
  font-size: 24rpx;
  color: #0A0A0A;
  font-weight: 500;
}

.temp-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.temp-item {
  padding: 16rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #4A5565;
  border: 2rpx solid #E5E7EB;
}

.temp-item.active {
  background: #F0FDF4;
  border-color: #00C950;
  color: #00A63E;
  font-weight: 500;
}

.occasion-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.occasion-item {
  padding: 24rpx 16rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  text-align: center;
  border: 2rpx solid #E5E7EB;
}

.occasion-item.active {
  background: #F0FDF4;
  border-color: #00C950;
}

.occasion-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.occasion-name {
  font-size: 26rpx;
  color: #0A0A0A;
  font-weight: 500;
}

.outfit-recommend {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 24rpx 0;
  border: 1rpx solid #F3F4F6;
}

.recommend-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.recommend-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #101828;
}

.more-icon {
  width: 40rpx;
  height: 40rpx;
  background: #F3F4F6;
  border-radius: 12rpx;
  position: relative;
}

.more-icon::before,
.more-icon::after {
  content: '';
  position: absolute;
  background: #364153;
}

.more-icon::before {
  width: 16rpx;
  height: 3rpx;
  top: 12rpx;
  left: 8rpx;
}

.more-icon::after {
  width: 16rpx;
  height: 3rpx;
  top: 20rpx;
  left: 8rpx;
}

.recommend-items {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.recommend-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #F3F4F6;
}

.recommend-img {
  width: 100%;
  height: 280rpx;
  background: #F3F4F6;
}

.recommend-img image {
  width: 100%;
  height: 100%;
}

.img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FB64B6 0%, #C27AFF 100%);
  font-size: 64rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.recommend-name {
  padding: 16rpx;
  font-size: 26rpx;
  color: #0A0A0A;
  font-weight: 500;
}

.recommend-tip {
  background: #F9FAFB;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-top: 20rpx;
}

.recommend-tip text {
  font-size: 26rpx;
  color: #364153;
}

.tip-highlight {
  color: #00A63E;
  font-weight: 500;
}

.tip-desc {
  display: block;
  font-size: 24rpx;
  color: #6A7282;
  margin-top: 8rpx;
}

.save-outfit-btn {
  background: #AD46FF;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  margin-top: 20rpx;
}

.save-outfit-btn text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
}

.week-list {
  margin-top: 16rpx;
  padding-bottom: 32rpx;
}

.week-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #F3F4F6;
}

.week-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.week-day {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.day-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #0A0A0A;
}

.day-date {
  font-size: 24rpx;
  color: #6A7282;
}

.week-weather-temp {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  font-size: 24rpx;
  color: #0A0A0A;
}

.temp {
  color: #AD46FF;
  font-weight: 500;
}

.week-suggest {
  background: #FAF5FF;
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: #4A5565;
}

.tips-card {
  display: flex;
  background: #FEFCE8;
  border-radius: 20rpx;
  padding: 24rpx;
  margin: 24rpx 0;
  border: 2rpx solid #FFF085;
}

.tips-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.tips-content {
  flex: 1;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #894B00;
  margin-bottom: 12rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tips-list text {
  font-size: 26rpx;
  color: #A65F00;
}

/* 搭配名称输入框 */
.outfit-name-input {
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 2rpx solid #E5E7EB;
  padding: 24rpx;
}

.name-input {
  font-size: 28rpx;
  color: #0A0A0A;
  width: 100%;
}

.input-placeholder {
  color: rgba(10, 10, 10, 0.50);
  font-size: 28rpx;
}

/* 衣物网格 */
.clothes-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.clothes-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  border: 2rpx solid #F3F4F6;
}

.clothes-item.active {
  border-color: #00C950;
  background: #F0FDF4;
}

.clothes-img {
  width: 100%;
  height: 320rpx;
  background: #F3F4F6;
}

.clothes-img image {
  width: 100%;
  height: 100%;
}

.clothes-name {
  padding: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #0A0A0A;
  text-align: center;
}

.clothes-type {
  padding: 0 16rpx 16rpx;
  font-size: 24rpx;
  color: #6A7282;
  text-align: center;
}

/* 已保存穿搭列表 */
.saved-list {
  margin-top: 16rpx;
}

.saved-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #F3F4F6;
}

.saved-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.saved-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #0A0A0A;
}

.saved-date {
  font-size: 24rpx;
  color: #6A7282;
}

.saved-items {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
}

.saved-clothes {
  flex-shrink: 0;
}

.saved-img {
  width: 120rpx;
  height: 120rpx;
  background: #F3F4F6;
  border-radius: 12rpx;
  overflow: hidden;
}

.saved-img image {
  width: 100%;
  height: 100%;
}

.empty-state {
  text-align: center;
  padding: 80rpx 32rpx;
  color: #6A7282;
  font-size: 28rpx;
}

/* 标签 */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  padding: 12rpx 24rpx;
  background: #F3F4F6;
  border-radius: 100rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #4A5565;
}

.tag-item.active {
  background: rgba(173, 70, 255, 0.1);
  color: #AD46FF;
}

/* 可删除的自定义标签 */
.tag-item.deletable {
  padding-right: 16rpx;
}

.tag-remove-icon {
  margin-left: 8rpx;
  font-size: 28rpx;
  color: #AD46FF;
}

.custom-tag-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.custom-tag-input {
  flex: 1;
  height: 84rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  border: 1.6rpx solid #E5E7EB;
  padding: 0 32rpx;
  font-size: 32rpx;
  color: #0A0A0A;
  box-sizing: border-box;
}

.custom-tag-input::placeholder {
  color: rgba(10, 10, 10, 0.5);
}

.custom-tag-btn {
  width: 128rpx;
  height: 84rpx;
  background: #AD46FF;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  color: #FFFFFF;
}

.custom-tags-display {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #E5E7EB;
}

.custom-tags-label {
  font-size: 24rpx;
  color: #6A7282;
  margin-bottom: 12rpx;
}

.custom-tag-item {
  padding: 12rpx 24rpx;
  background: rgba(173, 70, 255, 0.1);
  border-radius: 100rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #AD46FF;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.custom-tag-remove {
  font-size: 28rpx;
  color: #AD46FF;
  padding: 0 4rpx;
}

/* 保存按钮 */
.save-section {
  margin-top: 32rpx;
  margin-bottom: 32rpx;
}

.save-btn {
  width: 100%;
  background: linear-gradient(135deg, #AD46FF 0%, #8B2FD6 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
  padding: 16rpx 0;
  border-radius: 24rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(173, 70, 255, 0.3);
}

.save-btn.disabled {
  background: #E5E7EB;
  color: #9CA3AF;
  box-shadow: none;
}

/* 已保存穿搭元信息 */
.saved-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.saved-child {
  font-size: 24rpx;
  color: #4A5565;
  background: #F3F4F6;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
}

.saved-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.saved-tag {
  font-size: 22rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #AD46FF 0%, #8B2FD6 100%);
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

/* 编辑模式提示 */
.edit-mode-tip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #AD46FF 0%, #8B2FD6 100%);
  color: #FFFFFF;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.edit-cancel {
  font-size: 26rpx;
  opacity: 0.9;
  text-decoration: underline;
}
