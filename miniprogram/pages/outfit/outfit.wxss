}

.weather-option-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.weather-option-info {
  flex: 1;
}

.weather-option-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #101828;
}

.weather-option-desc {
  font-size: 24rpx;
  color: #6A7282;
  margin-top: 4rpx;
}

.city-input-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #E5E7EB;
}

.city-input-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #101828;
  margin-bottom: 16rpx;
}

.city-input {
  width: 100%;
  height: 80rpx;
  background: #F9FAFB;
  border-radius: 16rpx;
  border: 2rpx solid #E5E7EB;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #101828;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.city-confirm-btn {
  width: 100%;
  padding: 24rpx;
  background: linear-gradient(135deg, #FB64B6 0%, #C27AFF 100%);
  border-radius: 16rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(251, 100, 182, 0.3);
}

.city-confirm-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(251, 100, 182, 0.2);
}

.weather-modal-cancel {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #F3F4F6;
  border-radius: 16rpx;
  text-align: center;
  font-size: 28rpx;
  color: #6A7282;
  font-weight: 500;
  transition: all 0.3s ease;
}

.weather-modal-cancel:active {
  background: #E5E7EB;
  transform: scale(0.95);
}
