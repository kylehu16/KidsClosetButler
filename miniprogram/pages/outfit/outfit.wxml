<wxs module="utils">
module.exports = {
  inArray: function(arr, item) {
    if (!arr || !item) return false
    for (var i = 0; i < arr.length; i++) {
      if (arr[i] === item) return true
    }
    return false
  }
}
</wxs>

<view class="outfit-page">
  <view class="nav-bar gradient-bg">
    <view class="nav-title">👶 儿童衣橱管家</view>
    <view class="nav-subtitle">智能管理宝贝的每一件衣物</view>
  </view>

  <view class="outfit-content">
    <!-- 模式切换标签 -->
    <view class="mode-tabs">
      <view class="mode-tab {{modeTab === 0 ? 'active' : ''}}" data-mode="0" bindtap="switchMode">
        <text>AI推荐</text>
      </view>
      <view class="mode-tab {{modeTab === 2 ? 'active' : ''}}" data-mode="2" bindtap="switchMode">
        <text>已保存</text>
      </view>
      <view class="mode-tab {{modeTab === 3 ? 'active' : ''}}" data-mode="3" bindtap="switchMode">
        <text>穿搭记录</text>
      </view>
    </view>

    <!-- AI推荐模式 -->
    <view wx:if="{{modeTab === 0}}">
      <!-- 选择儿童 -->
      <view class="section">
        <view class="section-label">选择儿童</view>
        <view class="child-list">
          <view 
            wx:for="{{children}}" 
            wx:key="id"
            class="child-card {{utils.inArray(selectedChildIds, item.id) ? 'active' : ''}}"
            data-id="{{item.id}}"
            bindtap="selectChild"
          >
            <view class="child-avatar">{{item.avatar}}</view>
            <view class="child-info">
              <view class="child-name">{{item.name}}</view>
              <view class="child-desc">
                <text wx:if="{{item.age}}">{{item.age}}岁</text>
                <text wx:if="{{item.heightText}}"> · 身高{{item.heightText}}</text>
                <text wx:if="{{item.footLengthText}}"> · 脚长{{item.footLengthText}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 选择天气 -->
      <view class="section">
        <view class="section-label-row">
          <view class="section-label">选择天气</view>
          <view class="get-weather-btn" bindtap="getCurrentWeather">
            <text wx:if="{{locationLoading}}">获取中...</text>
            <text wx:else>📍 获取当前天气</text>
          </view>
        </view>
        <view class="weather-grid">
          <view 
            wx:for="{{weatherList}}" 
            wx:key="id"
            class="weather-item {{selectedWeather === item.id ? 'active' : ''}}"
            data-id="{{item.id}}"
            bindtap="selectWeather"
          >
            <view class="weather-icon">{{item.icon}}</view>
            <view class="weather-name">{{item.name}}</view>
          </view>
        </view>
      </view>

      <!-- 选择温度 -->
      <view class="section">
        <view class="section-label">选择温度</view>
        <view class="temp-grid">
          <view 
            wx:for="{{tempList}}" 
            wx:key="id"
            class="temp-item {{selectedTemp === item.id ? 'active' : ''}}"
            data-id="{{item.id}}"
            bindtap="selectTemp"
          >
            <text>{{item.name}}</text>
          </view>
        </view>
      </view>

      <!-- 选择场合 -->
      <view class="section">
        <view class="section-label">选择场合</view>
        <view class="occasion-grid">
          <view 
            wx:for="{{occasions}}" 
            wx:key="id"
            class="occasion-item {{selectedOccasion === item.id ? 'active' : ''}}"
            data-id="{{item.id}}"
            bindtap="selectOccasion"
          >
            <view class="occasion-icon">{{item.icon}}</view>
            <view class="occasion-name">{{item.name}}</view>
          </view>
        </view>
      </view>

      <!-- 今日推荐穿搭 -->
      <view class="outfit-recommend card">
        <view class="recommend-header">
          <text class="recommend-title">今日推荐穿搭</text>
          <view class="more-icon" bindtap="regenerate"></view>
        </view>
        <view class="recommend-items">
          <view 
            wx:for="{{recommendedOutfit}}" 
            wx:key="id"
            class="recommend-item"
          >
            <view class="recommend-img">
              <image wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill"/>
              <view wx:else class="img-placeholder">
                <text>{{item.name[0]}}</text>
              </view>
            </view>
            <view class="recommend-name">{{item.name}}</view>
          </view>
        </view>
        <view class="recommend-tip">
          <text>💡 为 <text class="tip-highlight">{{selectedChildName}}</text> 推荐的穿搭</text>
          <text class="tip-desc">适合{{selectedWeatherName}}天气，温度{{selectedTempName}}，{{selectedOccasionName}}场合穿着</text>
        </view>
        <view class="save-outfit-btn" bindtap="saveOutfit">
          <text>保存这套搭配</text>
        </view>
      </view>

      <!-- 未来天气与穿搭提醒 -->
      <view class="section">
        <view class="section-title-row">
          <text class="section-icon">📅</text>
          <text class="section-title-bold">未来天气与穿搭提醒</text>
        </view>
        <view class="week-list">
          <view 
            wx:for="{{weekOutfits}}" 
            wx:key="day"
            wx:if="{{index < 3}}"
            class="week-card card"
          >
            <view class="week-header">
              <view class="week-day">
                <text class="day-name">{{item.day}}</text>
                <text class="day-date">{{item.date}}</text>
              </view>
              <view class="week-weather-temp">
                <text>{{item.weatherIcon}} {{item.weather}}</text>
                <text class="temp">{{item.tempRange}}</text>
              </view>
            </view>
            <view class="week-suggest">{{item.suggest}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 已保存模式内容 -->
    <view wx:if="{{modeTab === 2}}">
      <!-- 添加搭配按钮 -->
      <view class="add-outfit-btn" bindtap="goToAddOutfit">
        <text class="add-icon">+</text>
        <text class="add-text">添加搭配</text>
      </view>

      <!-- 儿童筛选标签 -->
      <view class="filter-tabs">
        <view 
          class="filter-tab {{selectedSavedChildId === '' ? 'active' : ''}}"
          data-id=""
          bindtap="selectSavedChild"
        >全部</view>
        <view 
          wx:for="{{children}}"
          wx:key="id"
          class="filter-tab {{selectedSavedChildId === item.id ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="selectSavedChild"
        >{{item.name}}</view>
      </view>

      <!-- 已保存的穿搭列表 -->
      <view class="saved-list">
        <view 
          wx:for="{{filteredSavedOutfits}}" 
          wx:key="id" 
          class="saved-item card"
          bindtap="viewSavedOutfit"
          data-id="{{item.id}}"
        >
          <view class="saved-header">
            <text class="saved-name">{{item.name}}</text>
            <text class="saved-child" wx:if="{{item.childName}}">👤 {{item.childName}}</text>
          </view>
          <view class="saved-tags" wx:if="{{item.tagNames.length > 0}}">
            <text wx:for="{{item.tagNames}}" wx:key="index" class="saved-tag">{{item}}</text>
          </view>
          <view class="saved-items">
            <view wx:for="{{item.items}}" wx:for-item="clothes" wx:key="id" class="saved-clothes">
              <view class="saved-img">
                <image wx:if="{{clothes.image}}" src="{{clothes.image}}" mode="aspectFill"/>
                <view wx:else class="img-placeholder">
                  <text>{{clothes.name[0]}}</text>
                </view>
              </view>
              <view class="saved-clothes-name">{{clothes.name}}</view>
              <view class="saved-clothes-size" wx:if="{{clothes.size}}">{{clothes.size}}{{clothes.sizeUnit || 'cm'}}</view>
            </view>
          </view>
          <view class="saved-actions">
            <view class="wear-btn" catchtap="showWearModal" data-id="{{item.id}}">穿这套</view>
          </view>
        </view>
        <view wx:if="{{filteredSavedOutfits.length === 0}}" class="empty-state">
          <text>还没有保存的穿搭</text>
        </view>
      </view>
    </view>

    <!-- 穿搭记录模式内容 -->
    <view wx:if="{{modeTab === 3}}">
      <!-- 月份选择器 -->
      <view class="month-picker card">
        <view class="month-arrow-btn" bindtap="prevMonth">
          <text>‹</text>
        </view>
        <view class="month-center">
          <view class="month-info">
            <view class="month-text">{{currentYear}}年{{currentMonth}}月</view>
          </view>
        </view>
        <view class="month-arrow-btn" bindtap="nextMonth">
          <text>›</text>
        </view>
      </view>
      
      <!-- 筛选标签 -->
      <view class="filter-tabs">
        <view class="filter-tab {{!selectedChildId ? 'active' : ''}}" bindtap="selectAll">全部</view>
        <view 
          wx:for="{{children}}"
          wx:key="_id"
          class="filter-tab {{selectedChildId === item._id ? 'active' : ''}}"
          data-id="{{item._id}}"
          bindtap="selectRecordChild"
        >{{item.name}}</view>
      </view>
      
      <!-- 统计卡片 -->
      <view class="stats-row">
        <view class="stat-card">
          <view class="stat-num">{{stats.days}}</view>
          <view class="stat-label">记录天数</view>
        </view>
        <view class="stat-card">
          <view class="stat-num">{{stats.wears}}</view>
          <view class="stat-label">穿着次数</view>
        </view>
        <view class="stat-card">
          <view class="stat-num">{{stats.avgPerDay}}</view>
          <view class="stat-label">日均件数</view>
        </view>
      </view>
      
      <!-- 穿搭记录列表 -->
      <view class="records-list">
        <view 
          wx:for="{{filteredRecords}}"
          wx:key="date"
          class="record-card"
          bindtap="viewRecord"
          data-id="{{item._id}}"
          data-outfit-id="{{item.outfitId}}"
        >
          <!-- 日期头部 -->
          <view class="record-header">
            <view class="date-info">
              <view class="date-left">
                <view class="date-day">{{item.day}}</view>
                <view class="date-weekday">{{item.weekday}}</view>
              </view>
              <view class="date-full">{{item.dateStr}}</view>
            </view>
            <view class="delete-btn" catchtap="deleteRecord" data-id="{{item._id}}">删除</view>
          </view>
          
          <!-- 穿搭内容 -->
          <view class="record-content">
            <view class="outfit-title">
              <view class="outfit-dot {{item.childId ? 'green' : ''}}"></view>
              <text class="outfit-name">{{item.outfitName}}</text>
              <text class="outfit-child"> · {{item.childName}}</text>
            </view>
            <!-- 显示标签 -->
            <view class="outfit-tags" wx:if="{{item.tagNames.length > 0}}">
              <text wx:for="{{item.tagNames}}" wx:key="index" class="outfit-tag">{{item}}</text>
            </view>
            <view class="outfit-items">
              <view 
                wx:for="{{item.items}}"
                wx:for-item="clothing"
                wx:key="_id"
                class="outfit-item"
              >
                <view class="clothing-image">
                  <image wx:if="{{clothing.image}}" src="{{clothing.image}}" mode="aspectFill"/>
                  <view wx:else class="img-placeholder">{{clothing.name[0]}}</view>
                </view>
                <view class="clothing-name">{{clothing.name}}</view>
              </view>
            </view>
          </view>
        </view>
        <view wx:if="{{filteredRecords.length === 0}}" class="empty-state">
          <text>本月暂无穿搭记录</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 穿搭记录弹窗 -->
  <view class="wear-modal {{showWearModal ? 'show' : ''}}" bindtap="hideWearModal">
    <view class="wear-modal-content" catchtap="stopPropagation">
      <view class="wear-modal-title">记录穿搭</view>
      
      <!-- 选择儿童 -->
      <view class="wear-modal-section">
        <view class="wear-modal-label">选择儿童</view>
        <view class="wear-child-list">
          <view 
            wx:for="{{children}}"
            wx:key="id"
            class="wear-child-item {{wearSelectedChildId === item.id ? 'active' : ''}}"
            data-id="{{item.id}}"
            bindtap="selectWearChild"
          >
            <view class="wear-child-avatar">{{item.avatar}}</view>
            <view class="wear-child-name">{{item.name}}</view>
          </view>
        </view>
      </view>

      <!-- 选择日期 -->
      <view class="wear-modal-section">
        <view class="wear-modal-label">选择日期</view>
        <picker mode="date" value="{{wearDate}}" bindchange="onWearDateChange">
          <view class="wear-date-picker">
            <text>{{wearDate || '请选择日期'}}</text>
            <text class="wear-date-arrow">▸</text>
          </view>
        </picker>
      </view>

      <!-- 按钮 -->
      <view class="wear-modal-btns">
        <view class="wear-btn-cancel" bindtap="hideWearModal">取消</view>
        <view class="wear-btn-confirm" bindtap="confirmWear">确定</view>
      </view>
    </view>
  </view>

  <tab-bar currentIndex="1"></tab-bar>
</view>
