.tag-manage-page {
  min-height: 100vh;
  background: #F9FAFB;
  padding-bottom: 140rpx;
}

/* 渐变头部 */
.gradient-header {
  height: 180rpx;
  padding: 60rpx 32rpx 20rpx;
  background: linear-gradient(90deg, #FB64B6 0%, #C27AFF 100%);
  box-shadow: 0px 2px 4px -2px rgba(0, 0, 0, 0.10), 0px 4px 6px -1px rgba(0, 0, 0, 0.10);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.header-content {
  width: 100%;
  display: flex;
  align-items: center;
}

.nav-back {
  font-size: 36rpx;
  color: #FFFFFF;
  margin-right: 20rpx;
  font-weight: bold;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

/* 区域样式 */
.section {
  padding: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 24rpx;
}

.section-header .section-title {
  margin-bottom: 0;
}

.add-btn {
  font-size: 28rpx;
  color: #FB64B6;
  font-weight: 500;
  padding: 8rpx 24rpx;
  background: rgba(251, 100, 182, 0.1);
  border-radius: 20rpx;
}

/* 标签列表 */
.tag-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tag-info {
  flex: 1;
}

.tag-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1F2937;
}

.tag-type {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

.tag-usage {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

.tag-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 8rpx 24rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.action-btn.edit {
  background: rgba(59, 130, 246, 0.1);
  color: #3B82F6;
}

.action-btn.delete {
  background: rgba(239, 68, 68, 0.1);
  color: #EF4444;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: #9CA3AF;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.modal-content {
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.form-item {
  background: #F9FAFB;
  border-radius: 12rpx;
  padding: 20rpx;
}

.form-label {
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 8rpx;
}

.form-input {
  font-size: 28rpx;
  color: #1F2937;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.btn-cancel, .btn-confirm {
  flex: 1;
  padding: 24rpx;
  font-size: 28rpx;
  border-radius: 44rpx;
  text-align: center;
  font-weight: 500;
}

.btn-cancel {
  background: #F3F4F6;
  color: #4A5565;
}

.btn-confirm {
  background: linear-gradient(135deg, #FB64B6 0%, #C27AFF 100%);
  color: #FFFFFF;
}
