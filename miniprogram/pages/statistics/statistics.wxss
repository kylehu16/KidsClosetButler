.statistics-page {
  min-height: 100vh;
  background: #F9FAFB;
  padding-bottom: 140rpx;
}

/* 渐变头部 */
.gradient-header {
  height: 180rpx;
  padding: 60rpx 32rpx 20rpx;
  background: linear-gradient(90deg, #FB64B6 0%, #C27AFF 100%);
  box-shadow: 0px 2px 4px -2px rgba(0, 0, 0, 0.10), 0px 4px 6px -1px rgba(0, 0, 0, 0.10);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.header-content {
  width: 100%;
}

.header-icon {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.90);
}

/* 导航栏 */
.nav-bar {
  height: 0;
  background: transparent;
  border: none;
}

.nav-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon image {
  width: 32rpx;
  height: 32rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #0A0A0A;
  margin-left: 16rpx;
}

.overview-section {
  padding: 0 32rpx;
  margin-top: 24rpx;
}

.overview-card {
  padding: 32rpx;
}

.overview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.overview-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
}

.overview-period {
  font-size: 24rpx;
  color: #9CA3AF;
}

.overview-stats {
  display: flex;
  align-items: center;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 700;
}

.stat-label {
  font-size: 24rpx;
  color: #6B7280;
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #E5E7EB;
}

.section {
  padding: 32rpx;
}

.section-card {
  padding: 24rpx 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 24rpx;
}

.section-subtitle {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-left: 8rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
}

.section-icon image {
  width: 100%;
  height: 100%;
}

.category-stats {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.category-stat {
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.cat-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.cat-info {
  flex: 1;
}

.cat-name {
  font-size: 26rpx;
  color: #1F2937;
}

.cat-count {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

.cat-percent {
  font-size: 28rpx;
  font-weight: 600;
  color: #FB64B6;
}

.ranking-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.rank-num {
  width: 48rpx;
  height: 48rpx;
  background: #E5E7EB;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #374151;
  margin-right: 16rpx;
}

.rank-num.gold {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  color: #FFFFFF;
}

.rank-num.silver {
  background: linear-gradient(135deg, #C0C0C0 0%, #A8A8A8 100%);
  color: #FFFFFF;
}

.rank-num.bronze {
  background: linear-gradient(135deg, #CD7F32 0%, #B8860B 100%);
  color: #FFFFFF;
}

.rank-num.normal {
  background: #E5E7EB;
  color: #374151;
}

.cold-num {
  background: #E0F2FE;
  font-size: 28rpx;
}

.rank-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #F3F4F6;
  margin-right: 16rpx;
}

.rank-img image {
  width: 100%;
  height: 100%;
}

.outfit-clothes-row {
  display: flex;
  gap: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.outfit-clothes-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #F3F4F6;
}

.outfit-clothes-thumb image {
  width: 100%;
  height: 100%;
}

.img-placeholder.small {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FB64B6 0%, #C27AFF 100%);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: bold;
}

.img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FB64B6 0%, #C27AFF 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
}

.rank-info {
  flex: 1;
}

.rank-name {
  font-size: 26rpx;
  color: #1F2937;
  font-weight: 500;
}

.rank-meta {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

.rank-tip {
  font-size: 22rpx;
  color: #FB64B6;
  padding: 8rpx 16rpx;
  background: rgba(251, 100, 182, 0.1);
  border-radius: 20rpx;
}

.ranking-item.cold .rank-tip {
  color: #00A63E;
  background: rgba(0, 166, 62, 0.1);
}

.hot-tip {
  color: #FB6400;
  background: rgba(251, 100, 0, 0.1);
}

/* 沉睡榜单 - 卡片网格 */
.section-header-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-header-row .section-title {
  margin-bottom: 0;
}

.section-icon-text {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.sleepy-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.sleepy-card {
  overflow: hidden;
  padding: 0;
}

.sleepy-img {
  width: 100%;
  height: 200rpx;
  overflow: hidden;
  background: #F3F4F6;
}

.sleepy-img image {
  width: 100%;
  height: 100%;
}

.sleepy-info {
  padding: 16rpx;
}

.sleepy-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1F2937;
  margin-bottom: 4rpx;
}

.sleepy-category {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-bottom: 8rpx;
}

.sleepy-days {
  font-size: 24rpx;
  color: #FB923C;
}

.sleepy-days.never-worn {
  color: #9CA3AF;
}

/* 热门榜单 - 穿着次数 */
.rank-count {
  font-size: 28rpx;
  font-weight: 600;
  margin-left: auto;
  padding: 8rpx 16rpx;
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.count-num {
  color: #8B5CF6;
}

.count-unit {
  color: #374151;
  font-size: 24rpx;
  font-weight: 400;
}

/* 分页控件 */
.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 0;
  gap: 32rpx;
}

.page-btn {
  font-size: 28rpx;
  color: #FB64B6;
  padding: 12rpx 32rpx;
  background: rgba(251, 100, 182, 0.1);
  border-radius: 32rpx;
}

.page-btn.disabled {
  color: #D1D5DB;
  background: #F3F4F6;
}

.page-info {
  font-size: 28rpx;
  color: #6B7280;
}

/* 穿搭组合样式 */
.combo-item {
  flex-direction: column;
  align-items: flex-start;
  padding: 24rpx;
}

.combo-scroll {
  width: 100%;
  margin: 16rpx 0;
  white-space: nowrap;
}

.combo-items {
  display: inline-flex;
  gap: 16rpx;
  padding: 8rpx 0;
}

.combo-clothes {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 120rpx;
}

.combo-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #F3F4F6;
  margin-bottom: 8rpx;
}

.combo-img image {
  width: 100%;
  height: 100%;
}

.combo-name {
  font-size: 20rpx;
  color: #6B7280;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 120rpx;
}

.combo-count {
  font-size: 24rpx;
  color: #FB64B6;
  font-weight: 600;
  padding: 8rpx 16rpx;
  background: rgba(251, 100, 182, 0.1);
  border-radius: 20rpx;
  align-self: flex-end;
}

.empty-tip {
  text-align: center;
  color: #9CA3AF;
  font-size: 28rpx;
  padding: 48rpx 0;
}

/* 穿搭组合统计 */
.outfit-chart {
  background: #F9FAFB;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.chart-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 12rpx;
}

.chart-empty {
  font-size: 28rpx;
  color: #0A0A0A;
  display: block;
  margin-bottom: 4rpx;
}

.chart-hint {
  font-size: 24rpx;
  color: #99A1AF;
}

.outfit-stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.outfit-stat-item {
  flex: 1;
  padding: 32rpx;
  border-radius: 28rpx;
}

.outfit-stat-item.purple {
  background: #FAF5FF;
}

.outfit-stat-item.pink {
  background: #FDF2F8;
}

.outfit-stat-num {
  font-size: 48rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.purple .outfit-stat-num {
  color: #9810FA;
}

.pink .outfit-stat-num {
  color: #E60076;
}

.outfit-stat-label {
  font-size: 28rpx;
  color: #4A5565;
}

.usage-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-top: 1.6rpx solid #F3F4F6;
}

.usage-label {
  font-size: 28rpx;
  color: #4A5565;
}

.usage-value {
  font-size: 28rpx;
  font-weight: 500;
  color: #0A0A0A;
}

/* 穿搭统计报告 */
.report-card {
  margin: 32rpx;
  background: linear-gradient(135deg, #F3E8FF, #FCE7F3);
  border-radius: 32rpx;
  padding: 96rpx 64rpx;
  text-align: center;
  border: 3.2rpx solid #E9D4FF;
}

.report-icon {
  font-size: 72rpx;
  display: block;
  margin-bottom: 16rpx;
}

.report-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0A0A0A;
  display: block;
  margin-bottom: 16rpx;
}

.report-text {
  font-size: 28rpx;
  color: #364153;
}

.report-link {
  color: #9810FA;
  font-weight: 700;
}