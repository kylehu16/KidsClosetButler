<view class="statistics-page">
  <!-- 渐变头部 -->
  <view class="gradient-header">
    <view class="header-content">
      <view class="header-icon">👶 儿童衣橱管家</view>
      <view class="header-subtitle">智能管理宝贝的每一件衣物</view>
    </view>
  </view>
  
  <view class="overview-section">
    <view class="overview-card card">
      <view class="overview-header">
        <text class="overview-title">衣橱总览</text>
        <text class="overview-period">近30天</text>
      </view>
      <view class="overview-stats">
        <view class="stat-item">
          <view class="stat-num text-primary">{{totalCount}}</view>
          <view class="stat-label">衣物总数</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <view class="stat-num text-success">{{wornCount}}</view>
          <view class="stat-label">已穿次数</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <view class="stat-num text-ai">{{idleCount}}</view>
          <view class="stat-label">闲置衣物</view>
        </view>
      </view>
    </view>
  </view>
  
  <view class="section">
    <view class="section-title">分类统计</view>
    <view class="category-stats">
      <view 
        wx:for="{{categoryStats}}" 
        wx:key="id"
        class="category-stat card"
      >
        <view class="cat-icon">{{item.icon}}</view>
        <view class="cat-info">
          <view class="cat-name">{{item.name}}</view>
          <view class="cat-count">{{item.count}}件</view>
        </view>
        <view class="cat-percent">{{item.percent}}%</view>
      </view>
    </view>
  </view>
  
  <view class="section">
    <view class="section-title">热门榜单 TOP10</view>
    <view class="ranking-list">
      <view 
        wx:for="{{pagedHotList}}" 
        wx:key="_id"
        class="ranking-item card"
      >
        <view class="rank-num {{item.rankIndex === 1 ? 'gold' : item.rankIndex === 2 ? 'silver' : item.rankIndex === 3 ? 'bronze' : 'normal'}}">{{item.rankIndex}}</view>
        <view class="rank-img">
          <image wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill"/>
          <view wx:else class="img-placeholder">{{item.name[0]}}</view>
        </view>
        <view class="rank-info">
          <view class="rank-name">{{item.name}}</view>
          <view class="rank-meta">{{item.categoryText || item.category}}</view>
        </view>
        <view class="rank-count">
          <text class="count-num">{{item.wearCount}}</text>
          <text class="count-unit">次</text>
        </view>
      </view>
    </view>
    <view wx:if="{{hotList.length === 0}}" class="empty-tip">暂无穿着记录</view>
    
    <!-- 分页控件 -->
    <view class="pagination" wx:if="{{totalPages > 1}}">
      <view class="page-btn {{currentPage <= 1 ? 'disabled' : ''}}" bindtap="prevPage">上一页</view>
      <text class="page-info">{{currentPage}} / {{totalPages}}</text>
      <view class="page-btn {{currentPage >= totalPages ? 'disabled' : ''}}" bindtap="nextPage">下一页</view>
    </view>
  </view>
  
  <view class="section">
    <view class="section-header-row">
      <text class="section-title">沉睡榜单</text>
      <text class="section-subtitle">（超过30天没穿）</text>
    </view>
    <view class="sleepy-grid">
      <view 
        wx:for="{{pagedColdList}}" 
        wx:key="_id"
        class="sleepy-card card"
      >
        <view class="sleepy-img">
          <image wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill"/>
          <view wx:else class="img-placeholder">{{item.name[0]}}</view>
        </view>
        <view class="sleepy-info">
          <view class="sleepy-name">{{item.name}}</view>
          <view class="sleepy-category">{{item.categoryText || item.category}}</view>
          <view class="sleepy-days" wx:if="{{!item.neverWorn}}">已 {{item.days}} 天未穿</view>
          <view class="sleepy-days never-worn" wx:else>尚未穿过</view>
        </view>
      </view>
    </view>
    <view wx:if="{{coldList.length === 0}}" class="empty-tip">暂无沉睡衣物</view>
    
    <!-- 沉睡榜单分页控件 -->
    <view class="pagination" wx:if="{{coldTotalPages > 1}}">
      <view class="page-btn {{coldCurrentPage <= 1 ? 'disabled' : ''}}" bindtap="prevColdPage">上一页</view>
      <text class="page-info">{{coldCurrentPage}} / {{coldTotalPages}}</text>
      <view class="page-btn {{coldCurrentPage >= coldTotalPages ? 'disabled' : ''}}" bindtap="nextColdPage">下一页</view>
    </view>
  </view>
  
  <!-- 热门穿搭 TOP10 -->
  <view class="section">
    <view class="section-header-row">
      <text class="section-title">热门穿搭 TOP10</text>
      <text class="section-subtitle">（穿搭组合穿着次数）</text>
    </view>
    <view class="ranking-list">
      <view 
        wx:for="{{pagedOutfitHotList}}" 
        wx:key="_id"
        class="ranking-item card"
      >
        <view class="outfit-clothes-row">
          <view wx:for="{{item.items}}" wx:for-item="c" wx:key="_id" class="outfit-clothes-thumb">
            <image wx:if="{{c.image}}" src="{{c.image}}" mode="aspectFill"/>
            <view wx:else class="img-placeholder small">{{c.name[0]}}</view>
          </view>
        </view>
        <view class="rank-info">
          <view class="rank-name">{{item.name || '未命名穿搭'}}</view>
          <view wx:if="{{item.occasion || item.weather}}" class="rank-meta">{{item.occasion || ''}}{{item.occasion && item.weather ? ' · ' : ''}}{{item.weather || ''}}</view>
        </view>
        <view class="rank-count">
          <text class="count-num">{{item.wearCount}}</text>
          <text class="count-unit">次</text>
        </view>
      </view>
    </view>
    <view wx:if="{{outfitHotList.length === 0}}" class="empty-tip">暂无穿搭数据</view>
    
    <!-- 分页控件 -->
    <view class="pagination" wx:if="{{outfitTotalPages > 1}}">
      <view class="page-btn {{outfitCurrentPage <= 1 ? 'disabled' : ''}}" bindtap="prevOutfitPage">上一页</view>
      <text class="page-info">{{outfitCurrentPage}} / {{outfitTotalPages}}</text>
      <view class="page-btn {{outfitCurrentPage >= outfitTotalPages ? 'disabled' : ''}}" bindtap="nextOutfitPage">下一页</view>
    </view>
  </view>
  


  
  <tab-bar currentIndex="2"></tab-bar>
</view>