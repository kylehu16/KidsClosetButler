/* pages/authorize/authorize.wxss */
/* 授权引导页面样式 */

.authorize-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #FB64B6 0%, #C27AFF 100%);
  padding: 0 40rpx;
}

/* 自定义导航栏 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: transparent;
  z-index: 100;
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* 进度指示器 */
.progress-section {
  padding: 40rpx 60rpx;
}

.progress-bar {
  display: flex;
  align-items: center;
  justify-content: center;
}

.progress-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0.5;
  transition: all 0.3s ease;
}

.progress-step.active {
  opacity: 1;
}

.step-dot {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.progress-step.active .step-dot {
  background: #FFFFFF;
  color: #FB64B6;
}

.step-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.progress-step.active .step-text {
  color: #FFFFFF;
}

.progress-line {
  width: 120rpx;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.3);
  margin: 0 20rpx;
  margin-bottom: 40rpx;
  transition: all 0.3s ease;
}

.progress-line.active {
  background: #FFFFFF;
}

/* 步骤内容 */
.step-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.step-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.step-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 20rpx;
}

.step-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
  margin-bottom: 60rpx;
  line-height: 1.6;
}

/* 授权卡片 */
.auth-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.1);
}

.auth-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FB64B6 0%, #C27AFF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.auth-icon {
  font-size: 60rpx;
}

.auth-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 16rpx;
}

.auth-desc {
  font-size: 26rpx;
  color: #6B7280;
  text-align: center;
  line-height: 1.6;
}

/* 按钮样式 */
.btn-primary {
  width: 100% !important;
  height: 96rpx;
  background: linear-gradient(135deg, #FB64B6 0%, #C27AFF 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(251, 100, 182, 0.3);
  transition: all 0.3s ease;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.auth-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  text-align: center;
}

/* 用户信息卡片 */
.user-info-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.1);
}

/* 头像选择器 */
.avatar-wrapper {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  position: relative;
  margin-bottom: 20rpx;
}

.avatar-wrapper::after {
  border: none;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid #FFFFFF;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #FB64B6 0%, #C27AFF 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #FFFFFF;
}

.edit-icon {
  font-size: 24rpx;
}

.avatar-tip {
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 40rpx;
}

/* 昵称输入框 */
.nickname-wrapper {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.input-label {
  font-size: 28rpx;
  color: #1F2937;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  background: #F9FAFB;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  color: #1F2937;
  border: 2rpx solid #E5E7EB;
  transition: all 0.3s ease;
}

.nickname-input:focus {
  border-color: #FB64B6;
  background: #FFFFFF;
}

/* 错误提示 */
.error-toast {
  position: fixed;
  top: 200rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(239, 68, 68, 0.9);
  padding: 20rpx 40rpx;
  border-radius: 16rpx;
  z-index: 1000;
  animation: slideDown 0.3s ease;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateX(-50%) translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
}

.error-text {
  font-size: 28rpx;
  color: #FFFFFF;
  white-space: nowrap;
}
