.records-page {
  min-height: 100vh;
  background: #F9FAFB;
  padding-bottom: 140rpx;
}

/* 导航栏 */
.nav-bar {
  height: 180rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 20rpx;
  position: relative;
}

.gradient-bg {
  background: linear-gradient(90deg, #FB64B6 0%, #C27AFF 100%);
}

.nav-back {
  position: absolute;
  left: 32rpx;
  bottom: 20rpx;
  font-size: 40rpx;
  color: #FFFFFF;
  padding: 10rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

/* 内容区域 */
.content {
  padding: 32rpx 0;
}

/* 月份选择器 */
.month-picker {
  display: flex;
  align-items: center;
  padding: 32rpx;
  margin: 0 32rpx 24rpx 32rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  outline: 1.6rpx #F3F4F6 solid;
  outline-offset: -1.6rpx;
}

.month-arrow-btn {
  width: 64rpx;
  height: 64rpx;
  background: #F3F4F6;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #4A5565;
  font-weight: bold;
}

.month-arrow-btn text {
  line-height: 1;
}

.month-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.month-info {
  text-align: center;
}

.month-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #101828;
}

.month-label {
  font-size: 28rpx;
  color: #6A7282;
  margin-top: 4rpx;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  gap: 16rpx;
  margin: 0 32rpx 24rpx 32rpx;
  overflow-x: auto;
}

.filter-tabs::-webkit-scrollbar {
  display: none;
}

.filter-tab {
  padding: 12rpx 32rpx;
  background: #F3F4F6;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #4A5565;
  white-space: nowrap;
}

.filter-tab.active {
  background: #00C950;
  color: #FFFFFF;
}

/* 统计卡片 */
.stats-row {
  display: flex;
  gap: 16rpx;
  margin: 0 32rpx 24rpx 32rpx;
}

.stat-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 20rpx;
  outline: 1.6rpx #F3F4F6 solid;
  outline-offset: -1.6rpx;
  padding: 32rpx 16rpx;
  text-align: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #101828;
}

.stat-label {
  font-size: 24rpx;
  color: #6A7282;
  margin-top: 8rpx;
}

/* 记录卡片 */
.records-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin: 0 32rpx;
}

.record-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  outline: 1.6rpx #F3F4F6 solid;
  outline-offset: -1.6rpx;
  overflow: hidden;
}

.record-header {
  background: #F9FAFB;
  padding: 32rpx;
  border-bottom: 1.6rpx solid #F3F4F6;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.date-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.date-left {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.date-day {
  font-size: 36rpx;
  font-weight: 700;
  color: #101828;
  line-height: 1;
}

.date-weekday {
  font-size: 24rpx;
  color: #6A7282;
  margin-top: 4rpx;
}

.date-full {
  font-size: 28rpx;
  color: #4A5565;
}

.weather-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #6A7282;
}

/* 穿搭内容 */
.record-content {
  padding: 32rpx;
}

.outfit-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.outfit-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #4A5565;
  margin-right: 16rpx;
}

.outfit-dot.green {
  background: #00C950;
}

.outfit-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #364153;
}

.outfit-items {
  display: flex;
  gap: 24rpx;
}

.outfit-item {
  flex: 1;
  max-width: 200rpx;
}

.clothing-image {
  width: 200rpx;
  height: 266rpx;
  background: #F3F4F6;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.clothing-image image {
  width: 100%;
  height: 100%;
}

.img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FB64B6 0%, #C27AFF 100%);
  font-size: 64rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.clothing-name {
  font-size: 24rpx;
  color: #4A5565;
  text-align: center;
  margin-bottom: 4rpx;
}

.clothing-category {
  font-size: 24rpx;
  color: #99A1AF;
  text-align: center;
}
