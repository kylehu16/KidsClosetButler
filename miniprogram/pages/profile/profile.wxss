.profile-page {
  min-height: 100vh;
  background: #F9FAFB;
  padding-bottom: 140rpx;
}

/* 渐变头部 */
.gradient-header {
  height: 180rpx;
  padding: 60rpx 32rpx 20rpx;
  background: linear-gradient(90deg, #FB64B6 0%, #C27AFF 100%);
  box-shadow: 0px 2px 4px -2px rgba(0, 0, 0, 0.10), 0px 4px 6px -1px rgba(0, 0, 0, 0.10);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.header-content {
  width: 100%;
}

.header-icon {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.90);
}

/* 用户信息卡片 */
.user-section {
  padding: 0 32rpx;
  margin-top: 24rpx;
}

.user-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  outline: 1.6rpx #F3F4F6 solid;
  outline-offset: -1.6rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
}

.user-avatar-icon {
  font-size: 72rpx;
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #101828;
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 28rpx;
  color: #6A7282;
}

.section {
  padding: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 24rpx;
}

.children-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.child-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
}

.child-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FB64B6 0%, #C27AFF 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: bold;
  margin-right: 20rpx;
}

.child-info {
  flex: 1;
}

.child-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1F2937;
}

.child-meta {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

.child-actions {
  display: flex;
  gap: 16rpx;
}

.action-icon {
  font-size: 32rpx;
  padding: 8rpx;
}

.add-child {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  border: 2rpx dashed #E5E7EB;
  background: transparent;
}

.add-icon {
  font-size: 40rpx;
  color: #FB64B6;
  margin-right: 12rpx;
}

.add-text {
  font-size: 28rpx;
  color: #FB64B6;
}

.menu-list {
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #1F2937;
}

.menu-arrow {
  font-size: 32rpx;
  color: #9CA3AF;
}

.version-info {
  text-align: center;
  padding: 40rpx;
  font-size: 24rpx;
  color: #9CA3AF;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.modal-content {
  width: 600rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.form-row .form-item {
  flex: 1;
}

.form-item {
  background: #F9FAFB;
  border-radius: 12rpx;
  padding: 20rpx;
}

.form-label {
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 8rpx;
}

.form-input {
  font-size: 28rpx;
  color: #1F2937;
}

.gender-options {
  display: flex;
  gap: 16rpx;
}

.gender-item {
  flex: 1;
  padding: 16rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  text-align: center;
  font-size: 26rpx;
  color: #4A5565;
  border: 2rpx solid transparent;
}

.gender-item.active {
  border-color: #FB64B6;
  background: rgba(251, 100, 182, 0.05);
  color: #FB64B6;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.btn-cancel, .btn-confirm {
  flex: 1;
  padding: 24rpx;
  font-size: 28rpx;
  border-radius: 44rpx;
}

.btn-cancel {
  background: #F3F4F6;
  color: #4A5565;
}

.btn-confirm {
  background: linear-gradient(135deg, #FB64B6 0%, #C27AFF 100%);
  color: #FFFFFF;
}