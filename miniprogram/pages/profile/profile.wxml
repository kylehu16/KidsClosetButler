<view class="profile-page">
  <!-- 渐变头部 -->
  <view class="gradient-header">
    <view class="header-content">
      <view class="header-icon">👶 儿童衣橱管家</view>
      <view class="header-subtitle">智能管理宝贝的每一件衣物</view>
    </view>
  </view>
  
  <!-- 用户信息卡片 -->
  <view class="user-section">
    <view class="user-card">
      <!-- 头像按钮 -->
      <button class="avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
        <image wx:if="{{hasUserInfo && userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" class="avatar-img" mode="aspectFill"></image>
        <view wx:else class="avatar-placeholder">👨‍👩‍👧‍👦</view>
      </button>
      
      <!-- 昵称输入 -->
      <view class="user-info">
        <input 
          type="nickname" 
          class="nickname-input"
          value="{{userInfo.nickName || ''}}"
          placeholder="点击设置昵称"
          bindblur="onInputNickname"
        />
        <view class="user-role" wx:if="{{hasUserInfo && userInfo.gender}}">{{userInfo.gender == 1 ? '宝爸' : '宝妈'}}</view>
      </view>
    </view>
  </view>
  
  <view class="section">
    <view class="section-title">宝贝管理</view>
    <view class="children-list">
      <view 
        wx:for="{{children}}" 
        wx:key="_id"
        class="child-card card"
        data-id="{{item._id}}"
        bindtap="goToEditChild"
      >
        <view class="child-avatar">{{item.name[0]}}</view>
        <view class="child-info">
          <view class="child-name">{{item.name}}</view>
          <view class="child-meta">{{item.age}}岁 | {{item.height}}cm<text wx:if="{{item.footLength}}"> | 脚长{{item.footLength}}mm</text></view>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="add-child card" bindtap="goToAddChild">
        <text class="add-icon">+</text>
        <text class="add-text">添加宝贝</text>
      </view>
    </view>
  </view>
  
  <view class="section">
    <view class="menu-list card">
      <view class="menu-item" bindtap="goToTagManage">
        <text class="menu-icon">🏷️</text>
        <text class="menu-text">标签管理</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToSettings">
        <text class="menu-icon">⚙️</text>
        <text class="menu-text">设置</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToHelp">
        <text class="menu-icon">❓</text>
        <text class="menu-text">帮助与反馈</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToAbout">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于我们</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>
  
  <view class="version-info">
    <text>V1.0.0</text>
  </view>
  
  <tab-bar currentIndex="3"></tab-bar>
</view>