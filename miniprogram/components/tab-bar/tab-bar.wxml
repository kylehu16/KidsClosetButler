<view class="tab-bar">
  <view 
    wx:for="{{tabList}}" 
    wx:key="id" 
    class="tab-item {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <view class="tab-icon">
      <image 
        wx:if="{{selected === index}}"
        src="/assets/icons/{{item.icon}}_active.png" 
        mode="aspectFit"
      />
      <image 
        wx:else
        src="/assets/icons/{{item.icon}}.png" 
        mode="aspectFit"
      />
    </view>
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>