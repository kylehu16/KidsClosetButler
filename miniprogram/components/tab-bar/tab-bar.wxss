.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 10rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 1000;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
  position: relative;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 4rpx;
}

.tab-icon image {
  width: 100%;
  height: 100%;
}

.tab-text {
  font-size: 22rpx;
  color: #4A5565;
}

.tab-item.active .tab-text {
  color: #00A63E;
  font-weight: 500;
}

.add-center {
  position: absolute;
  top: -30rpx;
}

.add-btn {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #FB64B6 0%, #C27AFF 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(251, 100, 182, 0.3);
}

.add-btn text {
  font-size: 48rpx;
  color: #FFFFFF;
  font-weight: bold;
  line-height: 1;
}