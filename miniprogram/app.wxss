page {
  background-color: #F9FAFB;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #1F2937;
  box-sizing: border-box;
}

.gradient-bg {
  background: linear-gradient(135deg, #FB64B6 0%, #C27AFF 100%);
}

.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.text-primary { color: #FB64B6; }
.text-success { color: #00A63E; }
.text-ai { color: #AD46FF; }
.text-gray { color: #9CA3AF; }

.btn-primary {
  background: linear-gradient(135deg, #FB64B6 0%, #C27AFF 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 44rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-success {
  background: linear-gradient(135deg, #00A63E 0%, #00C950 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 44rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-ai {
  background: linear-gradient(135deg, #AD46FF 0%, #7B61FF 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 44rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin: 4rpx;
}

.tag-pink { background: rgba(251, 100, 182, 0.1); color: #FB64B6; }
.tag-green { background: rgba(0, 166, 62, 0.1); color: #00A63E; }
.tag-purple { background: rgba(173, 70, 255, 0.1); color: #AD46FF; }
.tag-gray { background: #F3F4F6; color: #6B7280; }

.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}